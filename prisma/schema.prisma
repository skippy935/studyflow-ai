datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int            @id @default(autoincrement())
  email             String         @unique
  passwordHash      String
  displayName       String         @default("")
  avatarUrl         String?
  uiLanguage        String         @default("en")
  subscriptionTier  String         @default("free")
  trialEndDate      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLogin         DateTime?
  streak            Int            @default(0)
  lastStudyDate     DateTime?
  totalCardsLearned Int            @default(0)
  neuroMode         String         @default("normal")
  xp                Int            @default(0)
  badges            String         @default("[]")
  googleId          String?        @unique
  emailVerified     Boolean        @default(false)
  verifyCode        String?
  verifyCodeExpiry  DateTime?
  verifyAttempts    Int            @default(0)
  gradeLevel        String?
  schoolType        String?
  bundesland        String?
  learningStyle     String?
  preferredStudyTime String?

  userType          String         @default("student")

  decks             Deck[]
  quizzes           Quiz[]
  summaries         Summary[]
  studySessions     StudySession[]
  examinerSessions  ExaminerSession[]
  subjects          Subject[]
  studyTasks        StudyTask[]
  missedQuestions   MissedQuestion[]
  teacherProfile    TeacherProfile?
  classMembers      ClassMember[]
  submissions       Submission[]
  parentLinks       ParentChildLink[] @relation("ChildLinks")
  childLinks        ParentChildLink[] @relation("ParentLinks")
  ownedGroups       StudyGroup[]      @relation("OwnedGroups")
  groupMemberships  StudyGroupMember[] @relation("GroupMemberships")
}

model StudyGroup {
  id          Int               @id @default(autoincrement())
  name        String
  description String            @default("")
  joinCode    String            @unique
  ownerId     Int
  owner       User              @relation("OwnedGroups", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  members     StudyGroupMember[]
  sharedDecks SharedDeck[]
}

model StudyGroupMember {
  id        Int        @id @default(autoincrement())
  groupId   Int
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    Int
  user      User       @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime   @default(now())

  @@unique([groupId, userId])
}

model SharedDeck {
  id        Int        @id @default(autoincrement())
  groupId   Int
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  deckId    Int
  deck      Deck       @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sharedBy  Int
  sharedAt  DateTime   @default(now())

  @@unique([groupId, deckId])
}

model ParentChildLink {
  id         Int      @id @default(autoincrement())
  parentId   Int
  childId    Int
  parent     User     @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child      User     @relation("ChildLinks",  fields: [childId],  references: [id], onDelete: Cascade)
  status     String   @default("pending") // pending, accepted, rejected
  createdAt  DateTime @default(now())
  acceptedAt DateTime?

  @@unique([parentId, childId])
}

model TeacherProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolName         String   @default("")
  verificationStatus String   @default("pending")
  subjects           String   @default("[]")
  classes            Class[]
  createdAt          DateTime @default(now())
}

model Class {
  id          Int            @id @default(autoincrement())
  teacherId   Int
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name        String
  subject     String         @default("")
  gradeLevel  String         @default("")
  joinCode    String         @unique
  isArchived  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  members     ClassMember[]
  assignments Assignment[]
}

model ClassMember {
  id       Int      @id @default(autoincrement())
  classId  Int
  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([classId, userId])
}

model Assignment {
  id          Int          @id @default(autoincrement())
  classId     Int
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  description String       @default("")
  dueDate     DateTime?
  maxXp       Int          @default(10)
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    Int
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content      String     @default("")
  submittedAt  DateTime   @default(now())
  grade        Int?
  feedback     String     @default("")
  status       String     @default("submitted")

  @@unique([assignmentId, studentId])
}

model Subject {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  color     String   @default("#4F46E5")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks     Deck[]
}

model Deck {
  id            Int            @id @default(autoincrement())
  userId        Int
  subjectId     Int?
  name          String
  description   String         @default("")
  color         String         @default("#4F46E5")
  isFavorite    Boolean        @default(false)
  examDate      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  cards         Card[]
  studySessions StudySession[]
  studyTasks    StudyTask[]
  sharedDecks   SharedDeck[]
}

model Card {
  id          Int      @id @default(autoincrement())
  deckId      Int
  front       String
  back        String
  difficulty  String   @default("medium")
  easiness    Float    @default(2.5)
  interval    Int      @default(1)
  repetitions Int      @default(0)
  nextReview  DateTime @default(now())
  createdAt   DateTime @default(now())

  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model Quiz {
  id        Int            @id @default(autoincrement())
  userId    Int
  title     String
  topic     String         @default("")
  createdAt DateTime       @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions       QuizQuestion[]
  missedQuestions MissedQuestion[]
}

model QuizQuestion {
  id           Int     @id @default(autoincrement())
  quizId       Int
  type         String  @default("multiple_choice")
  question     String
  options      String?
  correct      String?
  explanation  String  @default("")
  sampleAnswer String  @default("")
  keywords     String?

  quiz            Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  missedQuestions MissedQuestion[]
}

model Summary {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  topic     String   @default("")
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExaminerSession {
  id            Int               @id @default(autoincrement())
  userId        Int
  materialName  String
  materialType  String            @default("paste")
  wordCount     Int               @default(0)
  difficulty    String            @default("standard")
  questionCount Int               @default(10)
  focusArea     String?
  messages      Json              @default("[]")
  stats         Json              @default("{}")
  gapAnalysis   Json?
  exchangeCount Int               @default(0)
  completed     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  completedAt   DateTime?

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  material      ExaminerMaterial?
}

model ExaminerMaterial {
  id            Int             @id @default(autoincrement())
  sessionId     Int             @unique
  extractedText String
  createdAt     DateTime        @default(now())

  session       ExaminerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model MissedQuestion {
  id         Int          @id @default(autoincrement())
  userId     Int
  questionId Int
  quizId     Int
  timesWrong Int          @default(1)
  lastSeenAt DateTime     @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model StudyTask {
  id        Int       @id @default(autoincrement())
  userId    Int
  title     String
  notes     String    @default("")
  dueDate   DateTime?
  deckId    Int?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck      Deck?     @relation(fields: [deckId], references: [id], onDelete: SetNull)
}

model StudySession {
  id           Int      @id @default(autoincrement())
  userId       Int
  deckId       Int
  cardsStudied Int      @default(0)
  againCount   Int      @default(0)
  hardCount    Int      @default(0)
  goodCount    Int      @default(0)
  easyCount    Int      @default(0)
  studiedAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
}
